# Copyrighted test books and page images — never commit
*.pdf
*.epub
*.tif
*.tiff
# Exception: the bundled sample book is public domain (see its SOURCE.txt).
!chess_reader/assets/sample/*.pdf

# Large engine binaries — fetched by tool/fetch_stockfish.ps1
chess_reader/assets/engines/*.exe
chess_reader/assets/engines/*.nnue

# Vision model training: Python venv and checkpoints (the exported .onnx
# IS committed — assets/models/square_classifier.onnx).
chess_reader/tool/vision_train/.venv/
chess_reader/tool/vision_train/__pycache__/
*.pth

# Vision: dumped real board cells for offline validation (regenerated by dump_board_cells.dart)
chess_reader/tool/vision_train/real_cells/

# iOS code-signing private key (never commit)
cm_cert_key.pem
cm_cert_key
