# Define a global platform for the project. Must match (or be below) the
# Runner deployment target in the Xcode project (currently 16.0).
platform :ios, '16.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

# onnxruntime-objc / onnxruntime-c vendor statically linked binaries, which
# CocoaPods refuses to place inside a dynamic framework ("transitive
# dependencies that include statically linked binaries") and which trips App
# Store validation (ITMS-90208) when embedded as a standalone framework.
#
# We can't make linkage static globally, though: multistockfish_sf16 (the FFI
# Stockfish engine) is opened at runtime with
# `DynamicLibrary.open('multistockfish_sf16.framework/...')`, so it MUST be a
# dynamic framework or the engine fails with "Failed to load dynamic library".
#
# So we keep the default dynamic `use_frameworks!` and force ONLY the
# onnxruntime pods to build as static libraries (they then link into the
# flutter_onnxruntime framework). Everything else — including the
# multistockfish engines — stays a dynamic framework.
pre_install do |installer|
  installer.pod_targets.each do |pod|
    if pod.name.start_with?('onnxruntime')
      def pod.build_type
        Pod::BuildType.static_library
      end
    end
  end
end

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))

  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
  end
end
